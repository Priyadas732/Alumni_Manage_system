# Database Connection URL (PostgreSQL / Supabase)
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# JSON Web Token secret key for authentication signing
JWT_SECRET="generate_a_long_secure_random_string_here"

# Server port
PORT=5001

# Node environment (development | production)
NODE_ENV="development"

# Frontend origin — set to your deployed URL in production
# Example: ALLOWED_ORIGIN="https://your-app.onrender.com"
ALLOWED_ORIGIN="http://localhost:5173"
